{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    "schedule:weekly"
  ],
  "minimumReleaseAge": "7 days",
  "packageRules": [
    {
      "matchDepTypes": ["devDependencies", "dependencies"],
      "matchUpdateTypes": ["minor", "patch", "pin"],
      "groupName": "dependencies-non-major-updates"
    }
  ]
}
